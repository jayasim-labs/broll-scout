### Hardware concurrency guidelines

The companion should detect available resources and set executor sizes accordingly:

```python
import os
import psutil

def get_companion_concurrency():
    """Set concurrency limits based on editor's machine capabilities."""
    
    ram_gb = psutil.virtual_memory().total / (1024 ** 3)
    cpu_count = os.cpu_count()
    
    # Check if GPU is available for Ollama
    gpu_available = check_ollama_gpu()  # nvidia-smi or system_profiler
    
    if gpu_available:
        # GPU handles Ollama, CPU is free for Whisper and yt-dlp
        return {
            "ollama_workers": 3,    # GPU can handle 3 concurrent
            "whisper_workers": 1,   # CPU-bound, keep at 1
            "ytdlp_workers": 3,    # Network-bound, 3 is fine
        }
    elif ram_gb >= 16:
        # CPU-only but enough RAM
        return {
            "ollama_workers": 2,    # CPU Ollama is slower, limit to 2
            "whisper_workers": 1,   # Don't compete with Ollama for CPU
            "ytdlp_workers": 3,    # Network-bound, doesn't compete
        }
    else:
        # Low-resource machine (8GB)
        return {
            "ollama_workers": 1,    # One at a time
            "whisper_workers": 1,   # One at a time
            "ytdlp_workers": 2,    # Reduce slightly
        }
```

Report this in the companion health endpoint:

```python
@app.route("/health")
def health():
    concurrency = get_companion_concurrency()
    return jsonify({
        "status": "ok",
        "ollama": "running",
        "model": MATCHER_MODEL,
        "gpu_available": check_ollama_gpu(),
        "ram_gb": round(psutil.virtual_memory().total / (1024**3), 1),
        "concurrency": concurrency,
    })
