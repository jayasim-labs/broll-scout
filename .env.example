# B-Roll Scout Environment Variables

# OpenAI API (required - GPT-4o for translation, GPT-4o-mini for timestamps)
OPENAI_API_KEY=sk-...

# Google Gemini API (required - for query expansion)
GEMINI_API_KEY=

# YouTube Data API v3 (required - for video search and captions)
YOUTUBE_API_KEY=

# Google Custom Search API (optional - secondary search source)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# AWS DynamoDB (on EC2 with IAM role, these can be left blank)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=broll_

# API Authentication (optional - shared key for MVP)
API_KEY=

# Development
DEBUG=false

# Backend URL for Next.js proxy (Next.js dev server connects to this)
BACKEND_URL=http://localhost:8000
